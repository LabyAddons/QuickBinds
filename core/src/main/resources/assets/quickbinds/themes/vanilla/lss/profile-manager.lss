.container {

  width: 100%;
  height: 100%;

  Profile {
    height: 20;

    .buttons {
      alignment: right;
      height: 100%;
      width: fit-content;

      Button {
        width: 20;
        height: 20;
      }
    }
  }
}

.profile-add-button {
  left: 50%;
  alignment-x: center;
  height: 20;
  layout: fill;
  space-between-entries: 8;
  width: 90%;
  top: 90%;
}